<script>
  // Slideshow
  const slides = document.querySelectorAll('.slide');
  const indicators = document.querySelectorAll('.indicator');
  let current = 0, timer;
  function goTo(i) { slides[current].classList.remove('active'); indicators[current].classList.remove('active'); current = i; slides[current].classList.add('active'); indicators[current].classList.add('active'); }
  function startTimer() { timer = setInterval(() => goTo((current+1) % slides.length), 5000); }
  indicators.forEach(ind => { ind.addEventListener('click', () => { clearInterval(timer); goTo(parseInt(ind.dataset.index)); startTimer(); }); });
  startTimer();

  // Series tabs
  document.querySelectorAll('.series-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.series-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.series-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-' + btn.dataset.series).classList.add('active');
    });
  });

  // Expo tabs
  document.querySelectorAll('.expo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.expo-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.expo-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.expo-panel-musei').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const id = 'expo-' + btn.dataset.expo;
      const el = document.getElementById(id);
      if (el) el.classList.add('active');
    });
  });
</script>
