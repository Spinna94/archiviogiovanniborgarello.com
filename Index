<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Archivio Giovanni Borgarello</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --cream: #F5F0E8; --dark: #1A1814; --mid: #6B6560; --accent: #8B7355;
  --border: rgba(26,24,20,0.12);
  --font-display: 'Playfair Display', serif;
  --font-body: 'Inter', sans-serif;
}
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--cream); color: var(--dark); font-size: 15px; line-height: 1.7; font-weight: 300; }

nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.2rem 3rem;
  background: rgba(245,240,232,0.93); backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border);
}
.nav-logo { font-family: var(--font-display); font-size: 1rem; letter-spacing: 0.06em; color: var(--dark); text-decoration: none; }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--dark); }

/* HERO */
.hero { position: relative; height: 100vh; overflow: hidden; }
.slide { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 0 3rem 5rem; opacity: 0; transition: opacity 1.4s ease; }
.slide.active { opacity: 1; }
.slide-bg { position: absolute; inset: 0; z-index: 0; }
.slide-1 .slide-bg { background: linear-gradient(160deg, #D4C9B5 0%, #BFB09A 50%, #A89880 100%); }
.slide-2 .slide-bg { background: linear-gradient(135deg, #C5B9A6 0%, #B0A48E 50%, #9E9180 100%); }
.slide-3 .slide-bg { background: linear-gradient(170deg, #E0D8CC 0%, #C8BCA8 50%, #B5A892 100%); }
.slide-sculpture { position: absolute; inset: 0; z-index: 1; display: flex; align-items: center; justify-content: center; opacity: 0.13; }
.slide-overlay { position: absolute; inset: 0; z-index: 2; background: linear-gradient(to top, rgba(26,24,20,0.55) 0%, transparent 60%); }
.slide-content { position: relative; z-index: 3; }
.slide-number { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(245,240,232,0.5); margin-bottom: 0.8rem; }
.slide-title { font-family: var(--font-display); font-size: clamp(0.9rem, 1.5vw, 1.2rem); font-weight: 500; color: rgba(245,240,232,0.85); margin-bottom: 0.25rem; }
.slide-meta { font-size: 0.72rem; color: rgba(245,240,232,0.45); letter-spacing: 0.05em; }
.hero-header { position: absolute; bottom: 5rem; left: 3rem; z-index: 10; pointer-events: none; }
.hero-label { font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(245,240,232,0.55); margin-bottom: 1rem; }
.hero-title { font-family: var(--font-display); font-size: clamp(3rem, 7vw, 6rem); font-weight: 500; line-height: 1.0; color: rgba(245,240,232,0.95); }
.hero-title small { display: block; font-size: clamp(0.9rem, 2vw, 1.6rem); opacity: 0.55; margin-top: 0.4rem; font-style: italic; }
.slide-indicators { position: absolute; bottom: 2.5rem; right: 3rem; z-index: 10; display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; }
.indicator { width: 20px; height: 1px; background: rgba(245,240,232,0.3); cursor: pointer; transition: all 0.3s; }
.indicator.active { width: 40px; background: rgba(245,240,232,0.9); }

/* BASE */
section { padding: 6rem 3rem; }
.section-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
.section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 500; color: var(--dark); margin-bottom: 2rem; line-height: 1.2; }
.divider { width: 40px; height: 1px; background: var(--accent); margin: 1.5rem 0; }

/* GALLERIA */
#galleria { background: #EDE7DA; }
.gallery-intro { max-width: 560px; margin-bottom: 1rem; }
.gallery-intro p { font-size: 0.88rem; color: var(--mid); }
.series-nav { display: flex; gap: 0; margin-bottom: 3rem; border-bottom: 1px solid var(--border); }
.series-btn { padding: 0.7rem 1.4rem; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); background: none; border: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.2s; font-family: var(--font-body); }
.series-btn:hover { color: var(--dark); }
.series-btn.active { color: var(--dark); border-bottom-color: var(--accent); }
.series-panel { display: none; }
.series-panel.active { display: block; }
.series-header { margin-bottom: 2rem; }
.series-header h3 { font-family: var(--font-display); font-size: 1.4rem; font-weight: 500; color: var(--dark); margin-bottom: 0.5rem; }
.series-header p { font-size: 0.83rem; color: var(--mid); max-width: 520px; line-height: 1.8; }
.gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.gallery-item { cursor: pointer; transition: transform 0.3s ease; }
.gallery-item:hover { transform: translateY(-4px); }
.gallery-img { width: 100%; aspect-ratio: 3/4; background: #C8BBA8; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
.gallery-img.wide { aspect-ratio: 4/3; }
.gallery-img.square { aspect-ratio: 1/1; }
.gallery-featured { grid-column: span 2; }
.gallery-placeholder { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; opacity: 0.28; }
.gallery-placeholder svg { width: 44px; height: 44px; }
.gallery-placeholder span { font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dark); }
.gallery-overlay { position: absolute; inset: 0; background: rgba(26,24,20,0); transition: background 0.3s; display: flex; align-items: flex-end; padding: 1rem; }
.gallery-item:hover .gallery-overlay { background: rgba(26,24,20,0.35); }
.gallery-overlay-text { color: white; opacity: 0; transition: opacity 0.3s; font-size: 0.72rem; letter-spacing: 0.08em; }
.gallery-item:hover .gallery-overlay-text { opacity: 1; }
.gallery-meta { margin-top: 0.7rem; }
.gallery-meta h4 { font-family: var(--font-display); font-size: 0.92rem; font-weight: 500; color: var(--dark); }
.gallery-meta p { font-size: 0.72rem; color: var(--mid); margin-top: 0.1rem; }

/* BIOGRAFIA */
#biografia { background: var(--cream); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.bio-img { width: 100%; aspect-ratio: 3/4; background: #C8BBA8; display: flex; align-items: center; justify-content: center; }
.bio-img-caption { margin-top: 0.8rem; font-size: 0.68rem; color: var(--mid); letter-spacing: 0.05em; }
.bio-content { padding-top: 2rem; }
.bio-text { font-size: 0.88rem; color: var(--mid); line-height: 1.9; margin-bottom: 1.2rem; }
.bio-quote { border-left: 2px solid var(--accent); padding-left: 1.5rem; margin: 2rem 0; font-family: var(--font-display); font-size: 1.05rem; font-weight: 500; color: var(--dark); line-height: 1.6; font-style: italic; }
.bio-dates { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 0; }
.bio-date-row { display: flex; gap: 1.5rem; font-size: 0.8rem; padding: 0.8rem 0; border-bottom: 1px solid var(--border); }
.bio-date-year { font-family: var(--font-display); font-weight: 500; color: var(--accent); min-width: 60px; }
.bio-date-text { color: var(--mid); }

/* ESPOSIZIONI */
#esposizioni { background: #EDE7DA; }
.expo-intro { max-width: 560px; margin-bottom: 1rem; }
.expo-intro p { font-size: 0.88rem; color: var(--mid); }
.expo-tabs { display: flex; gap: 0; margin-bottom: 3.5rem; border-bottom: 1px solid var(--border); }
.expo-btn { padding: 0.7rem 1.6rem; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid); background: none; border: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.2s; font-family: var(--font-body); }
.expo-btn:hover { color: var(--dark); }
.expo-btn.active { color: var(--dark); border-bottom-color: var(--accent); }
.expo-panel { display: none; }
.expo-panel.active { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
.expo-col-title { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--border); }
.expo-col { padding-right: 3rem; border-right: 1px solid var(--border); padding-left: 0; }
.expo-col:last-child { border-right: none; padding-right: 0; padding-left: 3rem; }
.expo-col:nth-child(2) { padding-left: 3rem; }
.expo-entry { display: flex; gap: 1.2rem; padding: 0.55rem 0; border-bottom: 1px solid rgba(26,24,20,0.06); align-items: baseline; }
.expo-entry:last-child { border-bottom: none; }
.expo-year { font-family: var(--font-display); font-size: 0.78rem; font-weight: 500; color: var(--accent); min-width: 38px; flex-shrink: 0; }
.expo-place { font-size: 0.78rem; color: var(--mid); line-height: 1.5; }
.expo-place strong { display: block; font-weight: 400; color: var(--dark); font-size: 0.8rem; }

/* pannello musei — full width diverso */
.expo-panel-musei { display: none; }
.expo-panel-musei.active { display: block; }
.musei-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; }
.musei-col { padding-right: 4rem; border-right: 1px solid var(--border); }
.musei-col:last-child { border-right: none; padding-right: 0; padding-left: 4rem; }
.museo-entry { padding: 0.7rem 0; border-bottom: 1px solid rgba(26,24,20,0.06); }
.museo-entry:last-child { border-bottom: none; }
.museo-name { font-size: 0.82rem; color: var(--dark); font-weight: 400; }
.museo-place { font-size: 0.72rem; color: var(--mid); margin-top: 0.1rem; }

/* CHI SIAMO */
#chisiamo { background: var(--dark); color: var(--cream); }
#chisiamo .section-label { color: #A09070; }
#chisiamo .section-title { color: var(--cream); }
.chisiamo-text { font-size: 0.88rem; color: rgba(245,240,232,0.6); line-height: 1.9; margin-bottom: 1.2rem; max-width: 640px; }
.chisiamo-detail { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 3rem; }
.chisiamo-box { padding: 1.5rem; border: 1px solid rgba(245,240,232,0.1); }
.chisiamo-box-label { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: #A09070; margin-bottom: 0.6rem; }
.chisiamo-box-text { font-size: 0.83rem; color: rgba(245,240,232,0.55); line-height: 1.8; }

/* CONTATTI */
#contatti { background: var(--cream); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
.contact-info { display: flex; flex-direction: column; gap: 2rem; margin-top: 1rem; }
.contact-row { padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
.contact-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
.contact-value { font-family: var(--font-display); font-size: 1rem; font-weight: 500; color: var(--dark); }
.contact-form { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--mid); }
.form-input { background: transparent; border: none; border-bottom: 1px solid var(--border); padding: 0.6rem 0; font-family: var(--font-body); font-size: 0.88rem; color: var(--dark); outline: none; transition: border-color 0.2s; }
.form-input:focus { border-color: var(--accent); }
.form-textarea { resize: none; height: 100px; }
.btn-submit { align-self: flex-start; background: var(--dark); color: var(--cream); border: none; padding: 0.85rem 2.5rem; font-family: var(--font-body); font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; transition: background 0.2s; margin-top: 0.5rem; }
.btn-submit:hover { background: var(--accent); }

footer { background: var(--dark); color: rgba(245,240,232,0.3); padding: 2.5rem 3rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.68rem; letter-spacing: 0.08em; }
footer .footer-logo { font-family: var(--font-display); font-size: 0.88rem; color: rgba(245,240,232,0.5); }
</style>
</head>
<body>

<nav>
  <a href="#" class="nav-logo">Archivio Giovanni Borgarello</a>
  <ul class="nav-links">
    <li><a href="#galleria">Galleria</a></li>
    <li><a href="#biografia">Biografia</a></li>
    <li><a href="#esposizioni">Esposizioni</a></li>
    <li><a href="#chisiamo">Chi Siamo</a></li>
    <li><a href="#contatti">Contatti</a></li>
  </ul>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="slide slide-1 active">
    <div class="slide-bg"></div>
    <div class="slide-sculpture">
      <svg width="320" height="400" viewBox="0 0 320 400" fill="none">
        <ellipse cx="160" cy="310" rx="85" ry="16" fill="#1A1814"/>
        <rect x="142" y="55" width="36" height="258" rx="18" fill="#1A1814"/>
        <ellipse cx="160" cy="54" rx="52" ry="60" fill="#1A1814"/>
        <ellipse cx="160" cy="36" rx="26" ry="30" fill="#C8BBA8"/>
      </svg>
    </div>
    <div class="slide-overlay"></div>
    <div class="slide-content">
      <p class="slide-number">01 — 03</p>
      <p class="slide-title">Serie Presenze — Figura archetipica</p>
      <p class="slide-meta">Legno · Collezione privata · [foto da inserire]</p>
    </div>
  </div>
  <div class="slide slide-2">
    <div class="slide-bg"></div>
    <div class="slide-sculpture">
      <svg width="320" height="400" viewBox="0 0 320 400" fill="none">
        <ellipse cx="160" cy="340" rx="75" ry="12" fill="#1A1814"/>
        <path d="M125 320 Q95 195 138 108 Q160 52 182 108 Q225 195 195 320 Z" fill="#1A1814"/>
        <ellipse cx="160" cy="104" rx="32" ry="38" fill="#B5A892"/>
      </svg>
    </div>
    <div class="slide-overlay"></div>
    <div class="slide-content">
      <p class="slide-number">02 — 03</p>
      <p class="slide-title">Serie Stilizzazioni — Forma verticale</p>
      <p class="slide-meta">Marmo di Carrara · Opera museale · [foto da inserire]</p>
    </div>
  </div>
  <div class="slide slide-3">
    <div class="slide-bg"></div>
    <div class="slide-sculpture">
      <svg width="320" height="400" viewBox="0 0 320 400" fill="none">
        <rect x="120" y="290" width="80" height="14" rx="2" fill="#1A1814"/>
        <rect x="148" y="108" width="24" height="184" rx="4" fill="#1A1814"/>
        <ellipse cx="160" cy="104" rx="46" ry="52" fill="#1A1814"/>
        <ellipse cx="160" cy="88" rx="22" ry="26" fill="#C8BBA8"/>
        <rect x="138" y="165" width="44" height="6" rx="3" fill="#BFB09A"/>
      </svg>
    </div>
    <div class="slide-overlay"></div>
    <div class="slide-content">
      <p class="slide-number">03 — 03</p>
      <p class="slide-title">Opere pubbliche — Spazio urbano</p>
      <p class="slide-meta">Bronzo · Piemonte · [foto da inserire]</p>
    </div>
  </div>
  <div class="hero-header">
    <p class="hero-label">Scultore · Cambiano, Torino · 1950</p>
    <h1 class="hero-title">Giovanni<br>Borgarello<small>Archivio ufficiale</small></h1>
  </div>
  <div class="slide-indicators">
    <div class="indicator active" data-index="0"></div>
    <div class="indicator" data-index="1"></div>
    <div class="indicator" data-index="2"></div>
  </div>
</div>

<!-- GALLERIA -->
<section id="galleria">
  <div class="gallery-intro">
    <p class="section-label">Le opere</p>
    <h2 class="section-title">Galleria</h2>
    <p>Il corpus di Borgarello si organizza in cicli tematici distinti, ciascuno con una sua voce materica e concettuale. Quarant'anni di ricerca sulla forma, il simbolo e la presenza scultorea nello spazio.</p>
  </div>
  <div class="series-nav">
    <button class="series-btn active" data-series="presenze">Presenze</button>
    <button class="series-btn" data-series="stilizzazioni">Stilizzazioni</button>
    <button class="series-btn" data-series="pubbliche">Opere pubbliche</button>
    <button class="series-btn" data-series="materie">Per materia</button>
  </div>
  <div class="series-panel active" id="panel-presenze">
    <div class="series-header"><h3>Presenze</h3><p>Figure umane stilizzate che si protendono verso l'alto con una spiritualità quasi arcaica. Il soggetto è la figura come archetipo — forme primarie sospese tra immanenza e trascendenza.</p></div>
    <div class="gallery-grid">
      <div class="gallery-item gallery-featured"><div class="gallery-img wide"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><ellipse cx="24" cy="40" rx="12" ry="3" fill="#1A1814"/><rect x="20" y="10" width="8" height="30" rx="4" fill="#1A1814"/><ellipse cx="24" cy="9" rx="9" ry="10" fill="#1A1814" opacity="0.7"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Presenza I</h4><p>Legno di noce · h 95 cm · Collezione privata</p></div></div>
      <div class="gallery-item"><div class="gallery-img"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><path d="M18 44 Q12 30 19 14 Q24 5 29 14 Q36 30 30 44 Z" fill="#1A1814"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Presenza II</h4><p>Legno di ciliegio · h 78 cm</p></div></div>
      <div class="gallery-item"><div class="gallery-img square"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><rect x="16" y="8" width="16" height="32" rx="8" fill="#1A1814" opacity="0.65"/><rect x="20" y="4" width="8" height="10" rx="4" fill="#1A1814"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Presenza III</h4><p>Legno · Raccolta museale</p></div></div>
      <div class="gallery-item"><div class="gallery-img"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><ellipse cx="24" cy="30" rx="13" ry="10" fill="#1A1814" opacity="0.4"/><rect x="21" y="8" width="6" height="24" rx="3" fill="#1A1814"/><circle cx="24" cy="7" r="5" fill="#1A1814"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Presenza IV</h4><p>Legno e resina · Collezione privata</p></div></div>
    </div>
  </div>
  <div class="series-panel" id="panel-stilizzazioni">
    <div class="series-header"><h3>Stilizzazioni</h3><p>Opere che percorrono la tensione tra figurazione e astrazione pura. Borgarello riduce la forma al suo nucleo essenziale — sagome immobilizzate nell'attimo sottile che precede il movimento.</p></div>
    <div class="gallery-grid">
      <div class="gallery-item"><div class="gallery-img"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><path d="M14 44 Q8 26 18 12 L24 4 L30 12 Q40 26 34 44 Z" fill="#1A1814" opacity="0.75"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Stilizzazione I</h4><p>Marmo di Carrara · h 110 cm</p></div></div>
      <div class="gallery-item gallery-featured"><div class="gallery-img wide"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><ellipse cx="24" cy="38" rx="18" ry="6" fill="#1A1814" opacity="0.3"/><ellipse cx="24" cy="22" rx="10" ry="16" fill="#1A1814" opacity="0.7"/><ellipse cx="24" cy="10" rx="6" ry="8" fill="#1A1814"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Stilizzazione II</h4><p>Pietra serena · Galleria Losano, Pinerolo</p></div></div>
      <div class="gallery-item"><div class="gallery-img square"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><rect x="10" y="12" width="28" height="24" rx="14" fill="#1A1814" opacity="0.6"/><rect x="20" y="4" width="8" height="14" rx="4" fill="#1A1814"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Stilizzazione III</h4><p>Travertino · Collezione privata</p></div></div>
      <div class="gallery-item"><div class="gallery-img"><div class="gallery-placeholder"><svg viewBox="0 0 48 48" fill="none"><polygon points="24,4 40,44 8,44" fill="#1A1814" opacity="0.7"/></svg><span>Foto in arrivo</span></div><div class="gallery-overlay"><span class="gallery-overlay-text">Visualizza opera</span></div></div><div class="gallery-meta"><h4>Stilizzazione IV</h4><p>Granito · Mostra Pollenzo 2014</p></div></div>
    </div>
  </div>
  <div class="series-panel" id="panel-pubbliche">
